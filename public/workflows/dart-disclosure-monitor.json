            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "신규 공시 확인": {
      "main": [
        [
          {
            "node": "알림 메시지 생성",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "알림 메시지 생성": {
      "main": [
        [
          {
            "node": "Slack 공시 알림",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
