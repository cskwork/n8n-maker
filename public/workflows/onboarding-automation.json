    {
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "=[환영] {{ $json.name }}님, 입사를 축하합니다!",
        "message": "=안녕하세요, {{ $json.name }}님!\n\n{{ $json.department }}에 오신 것을 진심으로 환영합니다.\n\n입사일: {{ $json.startDate }}\n부서: {{ $json.department }}\n\n입사 전 준비사항과 첫날 안내는 별도로 전달드리겠습니다.\n궁금한 점이 있으시면 언제든 HR팀에 문의해주세요.\n\n감사합니다.\nHR팀 드림",
        "options": {}
      },
      "id": "gmail-welcome",
      "name": "환영 이메일",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [450, 300],
      "credentials": {
        "gmailOAuth2": {
          "id": "placeholder-gmail-oauth2",
          "name": "Gmail OAuth2 계정"
        }
      }
    },
    {
      "parameters": {
        "authentication": "oAuth2",
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "C_TEAM_CHANNEL_ID",
          "mode": "id"
        },
        "text": "=:tada: *신규 입사자를 소개합니다!*\n\n*이름:* {{ $('신규 입사자 등록').item.json.name }}\n*부서:* {{ $('신규 입사자 등록').item.json.department }}\n*입사일:* {{ $('신규 입사자 등록').item.json.startDate }}\n\n따뜻하게 맞이해주세요!",
        "otherOptions": {}
      },
      "id": "slack-team-notify",
      "name": "팀 채널 안내",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [650, 300],
      "credentials": {
        "slackOAuth2Api": {
          "id": "placeholder-slack-oauth2",
          "name": "Slack OAuth2 계정"
        }
      }
    },
    {
      "parameters": {
        "operation": "appendOrUpdate",
        "documentId": {
          "__rl": true,
          "value": "placeholder-spreadsheet-id",
          "mode": "id",
          "cachedResultName": "온보딩 체크리스트"
        },
        "sheetName": {
          "__rl": true,
          "value": "gid=0",
          "mode": "id",
          "cachedResultName": "Sheet1"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "이름": "={{ $('신규 입사자 등록').item.json.name }}",
            "부서": "={{ $('신규 입사자 등록').item.json.department }}",
            "입사일": "={{ $('신규 입사자 등록').item.json.startDate }}",
            "계정생성": "미완료",
            "장비지급": "미완료",
            "교육일정": "미배정"
          },
          "matchingColumns": [],
          "schema": []
        },
        "options": {
          "cellFormat": "USER_ENTERED",
          "useAppend": true
        }
      },
      "id": "sheets-checklist",
      "name": "체크리스트 생성",
