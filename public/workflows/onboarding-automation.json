          "id": "placeholder-sheets-oauth2",
          "name": "Google Sheets OAuth2 계정"
        }
      }
    },
    {
      "parameters": {
        "authentication": "oAuth2",
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "C_HR_CHANNEL_ID",
          "mode": "id"
        },
        "text": "=:white_check_mark: *온보딩 프로세스 시작*\n\n{{ $('신규 입사자 등록').item.json.name }}님의 온보딩이 시작되었습니다.\n\n- 환영 이메일 발송 완료\n- 팀 채널 공지 완료\n- 체크리스트 생성 완료\n\n계정 생성, 장비 지급, 교육 일정 배정을 진행해주세요.",
        "otherOptions": {}
