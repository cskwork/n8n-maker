---
/**
 * 템플릿 상세 페이지 (동적 라우트)
 * - Astro 5: getCollection + render from 'astro:content'
 * - 레이아웃: Breadcrumb > 제목+메타배지 > CTA > 다이어그램(플레이스홀더) > MDX body > 크레덴셜 > CTA > 관련 템플릿
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaSection from '../../components/detail/CtaSection.astro';
import CredentialBadges from '../../components/detail/CredentialBadges.astro';
import RelatedTemplates from '../../components/detail/RelatedTemplates.astro';
import WorkflowDiagram from '../../components/detail/WorkflowDiagram.astro';
import DiagramFallback from '../../components/detail/DiagramFallback.astro';

// 한글 매핑 (TemplateCard와 동일 — Astro 컴포넌트 export 제약으로 별도 정의)
const categoryLabel: Record<string, string> = {
  finance: '금융',
  marketing: '마케팅',
  hr: 'HR',
  it: 'IT/DevOps',
};

const difficultyLabel: Record<string, string> = {
  beginner: '초급',
  intermediate: '중급',
  advanced: '고급',
};

export async function getStaticPaths() {
  const allTemplates = await getCollection('templates');
  return allTemplates.map((template) => ({
    params: { id: template.id },
    props: { template, allTemplates },
  }));
}

const { template, allTemplates } = Astro.props;
const { title, description, category, difficulty, pricing, estimatedMinutes, credentials, workflowJsonPath, nodeCount, price } = template.data;

const { Content } = await render(template);

// 같은 카테고리의 다른 템플릿 최대 3개
const relatedTemplates = allTemplates
  .filter((t) => t.data.category === category && t.id !== template.id)
  .slice(0, 3);

// SoftwareApplication JSON-LD 구조화 데이터
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": title,
  "description": description,
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "inLanguage": "ko",
  "offers": {
    "@type": "Offer",
    "price": pricing === 'free' ? 0 : (price || 19000),
    "priceCurrency": "KRW",
  },
};

// 배지 스타일
const pricingClass = pricing === 'free'
  ? 'bg-green-50 text-green-700'
  : 'bg-amber-50 text-amber-700';
const pricingText = pricing === 'free' ? '무료' : '프리미엄';
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  jsonLd={jsonLd}
  breadcrumbs={[
    { label: categoryLabel[category] || category, href: `/n8n-maker/category/${category}` },
    { label: title, href: '' },
  ]}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    {/* 1. 제목 + 메타 배지 */}
    <section>
      <h1 class="text-2xl md:text-3xl font-bold text-surface-900 mb-4">{title}</h1>
      <div class="flex flex-wrap gap-2 mb-6">
        <span class="text-xs bg-surface-100 text-surface-600 px-2 py-1 rounded-full">
          {difficultyLabel[difficulty] || difficulty}
        </span>
        <span class="text-xs bg-surface-100 text-surface-600 px-2 py-1 rounded-full">
          {estimatedMinutes}분 설정
        </span>
        {nodeCount && (
          <span class="text-xs bg-surface-100 text-surface-600 px-2 py-1 rounded-full">
            {nodeCount}개 노드
          </span>
        )}
        <span class={`text-xs px-2 py-1 rounded-full ${pricingClass}`}>
          {pricingText}
        </span>
      </div>
    </section>

    {/* 2. 상단 CTA */}
    <section class="mb-8">
      <CtaSection pricing={pricing} workflowJsonPath={workflowJsonPath} title={title} price={price} />
    </section>

    {/* 3. 워크플로우 다이어그램 (n8n-demo + 폴백) */}
    <section class="mb-8">
      <WorkflowDiagram workflowJsonPath={workflowJsonPath} templateTitle={title}>
        <DiagramFallback slot="fallback" workflowJsonPath={workflowJsonPath} />
      </WorkflowDiagram>
    </section>

    {/* 4. 설명 (MDX body) */}
    <section class="mb-8">
      <article class="[&_h2]:text-xl [&_h2]:font-bold [&_h2]:mt-8 [&_h2]:mb-4 [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:mt-6 [&_h3]:mb-3 [&_p]:text-surface-600 [&_p]:mb-4 [&_p]:leading-relaxed [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:mb-4 [&_li]:text-surface-600 [&_li]:mb-1">
        <Content />
      </article>
    </section>

    {/* 5. 크레덴셜 배지 */}
    <section class="mb-8">
      <h2 class="text-lg font-bold text-surface-900 mb-3">필요한 크레덴셜</h2>
      <CredentialBadges credentials={credentials} />
    </section>

    {/* 6. 하단 CTA */}
    <section class="mb-12">
      <CtaSection pricing={pricing} workflowJsonPath={workflowJsonPath} title={title} price={price} />
    </section>

    {/* 7. 관련 템플릿 */}
    <section class="mt-12">
      <RelatedTemplates templates={relatedTemplates} />
    </section>
  </div>
</BaseLayout>
