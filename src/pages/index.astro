---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allTemplates = await getCollection('templates');
const sampleTemplates = allTemplates.slice(0, 3);

// 카테고리 정보
const categories = [
  {
    name: '금융',
    slug: 'finance',
    description: 'DART 공시, 주가 알림, 재무 보고서 자동화',
  },
  {
    name: '마케팅',
    slug: 'marketing',
    description: 'SNS 자동 포스팅, 리드 수집, 캠페인 관리',
  },
  {
    name: 'HR',
    slug: 'hr',
    description: '채용공고 수집, 지원자 관리, 온보딩 자동화',
  },
  {
    name: 'IT/DevOps',
    slug: 'it',
    description: '서버 모니터링, 배포 자동화, 알림 통합',
  },
];

// 카테고리 한글 매핑
const categoryLabel: Record<string, string> = {
  finance: '금융',
  marketing: '마케팅',
  hr: 'HR',
  it: 'IT/DevOps',
};

// 난이도 한글 매핑
const difficultyLabel: Record<string, string> = {
  beginner: '초급',
  intermediate: '중급',
  advanced: '고급',
};
---

<BaseLayout title="홈">
  <!-- 히어로 섹션 -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-surface-900 mb-4">
        n8n 워크플로우 마켓플레이스
      </h1>
      <p class="text-lg text-surface-600 mb-8 max-w-2xl mx-auto">
        비개발자를 위한 업무 자동화 템플릿 &#8212; 복사해서 바로 사용하세요
      </p>
      <a
        href="#categories"
        class="inline-flex items-center px-6 py-3 bg-primary-500 text-white font-semibold rounded-lg hover:bg-primary-600 transition-colors text-lg"
      >
        템플릿 둘러보기
      </a>
    </div>
  </section>

  <!-- 카테고리 미리보기 섹션 -->
  <section id="categories" class="py-16 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-surface-900 mb-8 text-center">
        카테고리별 템플릿
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {categories.map((cat) => (
          <a
            href={`/n8n-marketplace/category/${cat.slug}`}
            class="block p-6 bg-white rounded-xl border border-surface-200 hover:border-primary-300 hover:shadow-md transition-all group"
          >
            <div class="w-10 h-10 mb-4 text-primary-500 group-hover:text-primary-600 transition-colors">
              {cat.slug === 'finance' && (
                <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="4" y="32" width="32" height="2.5" rx="1.25" fill="currentColor" opacity="0.3" />
                  <rect x="6" y="8" width="28" height="3" rx="1.5" fill="currentColor" />
                  <polygon points="20,2 6,8 34,8" fill="currentColor" opacity="0.5" />
                  <rect x="9" y="13" width="4" height="17" rx="1" fill="currentColor" opacity="0.7" />
                  <rect x="18" y="13" width="4" height="17" rx="1" fill="currentColor" />
                  <rect x="27" y="13" width="4" height="17" rx="1" fill="currentColor" opacity="0.7" />
                  <rect x="4" y="30" width="32" height="2.5" rx="1.25" fill="currentColor" />
                </svg>
              )}
              {cat.slug === 'marketing' && (
                <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8 14 L8 26 L14 26 L14 14 Z" fill="currentColor" opacity="0.8" />
                  <path d="M14 12 L30 6 L30 34 L14 28 Z" fill="currentColor" />
                  <rect x="30" y="14" width="4" height="4" rx="2" fill="currentColor" opacity="0.5" />
                  <rect x="30" y="22" width="4" height="4" rx="2" fill="currentColor" opacity="0.5" />
                  <path d="M5 16 C2 18 2 22 5 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.4" />
                </svg>
              )}
              {cat.slug === 'hr' && (
                <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="20" cy="12" r="6" fill="currentColor" />
                  <path d="M8 34 C8 26 14 21 20 21 C26 21 32 26 32 34" fill="currentColor" opacity="0.6" />
                  <circle cx="32" cy="14" r="4" fill="currentColor" opacity="0.4" />
                  <path d="M32 20 C36 21 38 25 38 30" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.3" />
                  <circle cx="8" cy="14" r="4" fill="currentColor" opacity="0.4" />
                  <path d="M8 20 C4 21 2 25 2 30" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.3" />
                </svg>
              )}
              {cat.slug === 'it' && (
                <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M15 4 L12 8 L18 20 L12 32 L15 36 L25 36 L28 32 L22 20 L28 8 L25 4 Z" fill="currentColor" opacity="0.15" />
                  <circle cx="20" cy="20" r="7" stroke="currentColor" stroke-width="2.5" fill="none" />
                  <circle cx="20" cy="20" r="2.5" fill="currentColor" />
                  <rect x="18.5" y="2" width="3" height="6" rx="1.5" fill="currentColor" />
                  <rect x="18.5" y="32" width="3" height="6" rx="1.5" fill="currentColor" />
                  <rect x="2" y="18.5" width="6" height="3" rx="1.5" fill="currentColor" />
                  <rect x="32" y="18.5" width="6" height="3" rx="1.5" fill="currentColor" />
                  <rect x="7.2" y="7.2" width="3" height="5.5" rx="1.5" fill="currentColor" transform="rotate(-45 8.7 10)" />
                  <rect x="29.8" y="27.3" width="3" height="5.5" rx="1.5" fill="currentColor" transform="rotate(-45 31.3 30)" />
                  <rect x="29.8" y="7.2" width="3" height="5.5" rx="1.5" fill="currentColor" transform="rotate(45 31.3 10)" />
                  <rect x="7.2" y="27.3" width="3" height="5.5" rx="1.5" fill="currentColor" transform="rotate(45 8.7 30)" />
                </svg>
              )}
            </div>
            <h3 class="text-lg font-bold text-surface-900 mb-2">{cat.name}</h3>
            <p class="text-sm text-surface-500">{cat.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 샘플 템플릿 섹션 -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-surface-900 mb-8 text-center">
        인기 템플릿
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sampleTemplates.map((template) => (
          <div class="p-6 bg-white rounded-xl border border-surface-200 hover:shadow-md transition-shadow">
            <h3 class="font-bold text-surface-900 mb-2">{template.data.title}</h3>
            <p class="text-sm text-surface-500 mb-4 line-clamp-2">{template.data.description}</p>
            <div class="flex flex-wrap gap-2">
              <span class="text-xs bg-primary-50 text-primary-700 px-2 py-1 rounded-full font-medium">
                {categoryLabel[template.data.category] || template.data.category}
              </span>
              <span class="text-xs bg-surface-100 text-surface-600 px-2 py-1 rounded-full">
                {difficultyLabel[template.data.difficulty] || template.data.difficulty}
              </span>
              <span class={`text-xs px-2 py-1 rounded-full ${template.data.pricing === 'free' ? 'bg-green-50 text-green-700' : 'bg-amber-50 text-amber-700'}`}>
                {template.data.pricing === 'free' ? '무료' : '프리미엄'}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 시작하기 섹션 -->
  <section id="get-started" class="py-16 bg-primary-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-surface-900 mb-4">
        지금 바로 시작하세요
      </h2>
      <p class="text-surface-600 mb-8 max-w-xl mx-auto">
        n8n을 설치하고, 마음에 드는 워크플로우 템플릿을 다운로드해서 업무를 자동화하세요.
      </p>
      <a
        href="https://docs.n8n.io/hosting/installation/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center px-6 py-3 bg-primary-500 text-white font-semibold rounded-lg hover:bg-primary-600 transition-colors"
      >
        n8n 설치 가이드
      </a>
    </div>
  </section>
</BaseLayout>
