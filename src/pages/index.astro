---
import '../styles/global.css';
import { getCollection } from 'astro:content';

const allTemplates = await getCollection('templates');
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="n8n 워크플로우 템플릿 마켓플레이스 - 비개발자를 위한 업무 자동화" />
    <title>n8n 마켓플레이스</title>
  </head>
  <body class="min-h-screen bg-surface-50 text-surface-900 font-sans">
    <main class="max-w-4xl mx-auto px-4 py-16">
      <h1 class="text-4xl font-bold text-primary-600 mb-4">n8n 마켓플레이스</h1>
      <p class="text-lg text-surface-700 mb-4">비개발자를 위한 n8n 워크플로우 템플릿 마켓플레이스</p>

      <section>
        <h2 class="text-xl font-bold text-surface-800 mb-4">워크플로우 템플릿 ({allTemplates.length}개)</h2>
        <ul class="space-y-2">
          {allTemplates.map((template) => (
            <li class="p-4 bg-white rounded-lg border border-surface-200">
              <h3 class="font-bold text-primary-600">{template.data.title}</h3>
              <p class="text-sm text-surface-700">{template.data.description}</p>
              <div class="flex gap-2 mt-2">
                <span class="text-sm bg-primary-100 text-primary-700 px-2 py-0.5 rounded">{template.data.category}</span>
                <span class="text-sm bg-surface-100 text-surface-700 px-2 py-0.5 rounded">{template.data.difficulty}</span>
                <span class={`text-sm px-2 py-0.5 rounded ${template.data.pricing === 'free' ? 'bg-green-100 text-green-700' : 'bg-amber-100 text-amber-700'}`}>
                  {template.data.pricing === 'free' ? '무료' : '프리미엄'}
                </span>
              </div>
            </li>
          ))}
        </ul>
      </section>
    </main>
  </body>
</html>
