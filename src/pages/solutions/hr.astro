---
/**
 * /solutions/hr - HR 자동화 키워드 랜딩 페이지
 * 문제-해결형 구성: 고민 -> 해결 -> 관련 템플릿 -> CTA
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import TemplateCard from '../../components/catalog/TemplateCard.astro';
import { getCollection } from 'astro:content';

const allTemplates = await getCollection('templates');
const hrTemplates = allTemplates.filter((t) => t.data.category === 'hr');

const painPoints = [
  {
    title: '채용공고 일일이 검색',
    description: '여러 채용 사이트를 돌아다니며 공고를 하나씩 확인하느라 시간이 낭비됩니다.',
    icon: 'search',
  },
  {
    title: '자소서 작성 부담',
    description: '매 지원마다 자소서를 처음부터 새로 작성해야 해 부담이 큽니다.',
    icon: 'pen',
  },
  {
    title: '온보딩 절차 누락',
    description: '신입 직원 온보딩 시 해야 할 일들을 빠뜨려 혼란이 생깁니다.',
    icon: 'list',
  },
  {
    title: '업무 보고서 수동 작성',
    description: '주간/월간 업무 보고서를 매번 수동으로 정리하고 작성해야 합니다.',
    icon: 'report',
  },
];

const solutions = [
  {
    title: '채용공고 자동 수집',
    description: '사람인 등 채용 사이트에서 원하는 조건의 공고를 자동으로 수집하고 알려줍니다.',
    icon: 'collect',
  },
  {
    title: 'AI 자소서 생성',
    description: 'AI가 채용공고를 분석하고, 맞춤형 자기소개서 초안을 자동으로 작성합니다.',
    icon: 'ai',
  },
  {
    title: '신입 온보딩 자동화',
    description: '계정 생성, 문서 공유, 일정 등록 등 온보딩 체크리스트를 자동으로 실행합니다.',
    icon: 'checklist',
  },
  {
    title: '주간 업무 보고서 자동화',
    description: '팀원들의 업무 내용을 자동 수집하고 보고서를 생성하여 공유합니다.',
    icon: 'auto-report',
  },
];
---

<BaseLayout
  title="HR 자동화 - n8n으로 채용/인사 업무 자동화하기"
  description="채용공고 자동 수집, AI 자소서, 온보딩 자동화 등 HR 업무를 n8n으로 자동화하세요"
  ogType="website"
  breadcrumbs={[
    { label: 'HR 자동화', href: '/n8n-maker/solutions/hr' },
  ]}
>
  <!-- 히어로 섹션 -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-surface-900 mb-4">
        매일 수작업으로 채용/인사 업무 하느라<br class="hidden md:block" /> 힘드셨나요?
      </h1>
      <p class="text-lg text-surface-600 mb-8 max-w-2xl mx-auto">
        n8n 워크플로우 템플릿으로 채용공고 수집부터 온보딩까지,<br class="hidden md:block" />
        반복되는 HR 업무를 자동화하세요.
      </p>
    </div>
  </section>

  <!-- 고민 섹션 -->
  <section class="py-16 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-surface-900 mb-10 text-center">
        이런 고민, 하고 계시지 않나요?
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {painPoints.map((point) => (
          <div class="flex items-start gap-4 p-6 bg-white rounded-xl border border-surface-200">
            <div class="w-10 h-10 bg-red-50 rounded-lg flex items-center justify-center shrink-0">
              {point.icon === 'search' && (
                <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              )}
              {point.icon === 'pen' && (
                <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                </svg>
              )}
              {point.icon === 'list' && (
                <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                </svg>
              )}
              {point.icon === 'report' && (
                <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              )}
            </div>
            <div>
              <h3 class="font-bold text-surface-900 mb-1">{point.title}</h3>
              <p class="text-sm text-surface-500">{point.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 해결 섹션 -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-surface-900 mb-10 text-center">
        n8n으로 이렇게 해결합니다
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {solutions.map((sol) => (
          <div class="flex items-start gap-4 p-6 bg-white rounded-xl border border-primary-200">
            <div class="w-10 h-10 bg-primary-50 rounded-lg flex items-center justify-center shrink-0">
              {sol.icon === 'collect' && (
                <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                </svg>
              )}
              {sol.icon === 'ai' && (
                <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                </svg>
              )}
              {sol.icon === 'checklist' && (
                <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                </svg>
              )}
              {sol.icon === 'auto-report' && (
                <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              )}
            </div>
            <div>
              <h3 class="font-bold text-surface-900 mb-1">{sol.title}</h3>
              <p class="text-sm text-surface-500">{sol.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 관련 템플릿 목록 -->
  {hrTemplates.length > 0 && (
    <section class="py-16 bg-surface-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900 mb-10 text-center">
          HR 자동화 템플릿
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {hrTemplates.map((template) => (
            <TemplateCard
              title={template.data.title}
              description={template.data.description}
              category={template.data.category}
              difficulty={template.data.difficulty}
              pricing={template.data.pricing}
              nodeCount={template.data.nodeCount}
              estimatedMinutes={template.data.estimatedMinutes}
              slug={template.id}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA 섹션 -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-surface-900 mb-4">
        HR 업무 자동화를 시작하세요
      </h2>
      <p class="text-surface-600 mb-8 max-w-xl mx-auto">
        더 많은 HR 자동화 템플릿을 확인하고, 바로 다운로드하세요.
      </p>
      <a
        href="/n8n-maker/category/hr"
        class="inline-flex items-center px-6 py-3 bg-primary-500 text-white font-semibold rounded-lg hover:bg-primary-600 transition-colors text-lg"
      >
        템플릿 보러가기
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
