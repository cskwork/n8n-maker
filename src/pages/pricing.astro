---
/**
 * /pricing 페이지
 * 프리미엄 템플릿 안내 — 무료 vs 프리미엄 비교, 포함 사항, 문의 링크
 */
import BaseLayout from '../layouts/BaseLayout.astro';

// TODO: 실제 Google Form ID로 교체하세요
const GOOGLE_FORM_URL = 'https://docs.google.com/forms/d/e/PLACEHOLDER_FORM_ID/viewform';

const premiumFeatures = [
  {
    title: '워크플로우 JSON + 상세 설정 가이드',
    description: '바로 가져올 수 있는 완성된 워크플로우 파일과 단계별 설정 가이드를 함께 제공합니다.',
    icon: 'file',
  },
  {
    title: '1:1 커스터마이징 컨설팅 (이메일)',
    description: '비즈니스 환경에 맞게 워크플로우를 수정할 수 있도록 이메일로 맞춤 상담을 드립니다.',
    icon: 'chat',
  },
  {
    title: '에러 발생 시 해결 지원',
    description: '워크플로우 실행 중 문제가 발생하면 원인 분석과 해결 방법을 안내합니다.',
    icon: 'shield',
  },
  {
    title: '업데이트 시 무료 재다운로드',
    description: 'n8n 버전 업데이트에 맞춰 워크플로우가 갱신되면 무료로 다시 받을 수 있습니다.',
    icon: 'refresh',
  },
];

const faqs = [
  {
    question: '프리미엄 템플릿은 어떻게 받나요?',
    answer: 'Google Form으로 문의해 주시면, 확인 후 이메일로 워크플로우 JSON 파일과 설정 가이드를 전달해 드립니다.',
  },
  {
    question: '환불이 가능한가요?',
    answer: '디지털 상품 특성상 기본적으로 환불이 제한되지만, 문제가 있을 경우 문의해 주시면 성실히 협의하겠습니다.',
  },
  {
    question: '무료 템플릿과 프리미엄 템플릿의 차이는 뭔가요?',
    answer: '무료 템플릿은 기본적인 워크플로우를 제공하며, 프리미엄은 고급 자동화 로직과 함께 1:1 커스터마이징 컨설팅, 에러 해결 지원이 포함됩니다.',
  },
];
---

<BaseLayout
  title="가격 안내 - n8n 프리미엄 워크플로우 템플릿"
  description="n8n 프리미엄 워크플로우 템플릿 가격 안내. 무료 vs 프리미엄 비교, 포함 사항 확인."
  breadcrumbs={[{ label: '가격 안내', href: '' }]}
>
  <!-- 히어로 섹션 -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-surface-900 mb-4">
        프리미엄 워크플로우 템플릿
      </h1>
      <p class="text-lg text-surface-600 mb-2 max-w-2xl mx-auto">
        전문가가 설계한 고급 자동화 템플릿으로 업무를 혁신하세요
      </p>
      <p class="text-sm text-surface-400">
        무료로 시작하고, 필요할 때 프리미엄으로 업그레이드하세요
      </p>
    </div>
  </section>

  <!-- 무료 vs 프리미엄 비교 섹션 -->
  <section class="py-16 bg-surface-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-surface-900 mb-10 text-center">
        플랜 비교
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <!-- 무료 플랜 -->
        <div class="relative bg-white rounded-2xl border border-surface-200 p-8 flex flex-col">
          <h3 class="text-xl font-bold text-surface-900 mb-2">무료</h3>
          <p class="text-surface-500 text-sm mb-6">기본 워크플로우로 자동화를 시작하세요</p>
          <div class="mb-6">
            <span class="text-3xl font-bold text-surface-900">무료</span>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-surface-700">기본 워크플로우 템플릿</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-surface-700">커뮤니티 가이드</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-surface-700">즉시 다운로드</span>
            </li>
          </ul>
          <a
            href="/n8n-maker/"
            class="block text-center px-6 py-3 bg-surface-100 text-surface-700 font-semibold rounded-lg hover:bg-surface-200 transition-colors"
          >
            무료 템플릿 보기
          </a>
        </div>

        <!-- 프리미엄 플랜 -->
        <div class="relative bg-white rounded-2xl border-2 border-amber-400 p-8 flex flex-col shadow-lg">
          <!-- 추천 배지 -->
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="inline-block px-4 py-1 bg-amber-400 text-amber-900 text-xs font-bold rounded-full uppercase tracking-wider">
              추천
            </span>
          </div>
          <h3 class="text-xl font-bold text-surface-900 mb-2">프리미엄</h3>
          <p class="text-surface-500 text-sm mb-6">전문가 수준의 고급 자동화 워크플로우</p>
          <div class="mb-6">
            <span class="text-3xl font-bold text-surface-900">&#8361;19,000</span>
            <span class="text-surface-400 text-lg"> ~ &#8361;49,000</span>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-surface-700">고급 워크플로우 템플릿</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-surface-700">1:1 커스터마이징 가이드</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-surface-700">이메일 지원</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-surface-700">에러 해결 지원 포함</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-surface-700">업데이트 시 무료 재다운로드</span>
            </li>
          </ul>
          <a
            href={GOOGLE_FORM_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="block text-center px-6 py-3 bg-primary-500 text-white font-semibold rounded-lg hover:bg-primary-600 transition-colors"
          >
            구매 문의하기
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 프리미엄 포함 사항 상세 섹션 -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-surface-900 mb-10 text-center">
        프리미엄에 포함된 것
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {premiumFeatures.map((feature) => (
          <div class="flex items-start gap-4 p-6 bg-white rounded-xl border border-surface-200">
            <div class="w-10 h-10 bg-primary-50 rounded-lg flex items-center justify-center shrink-0">
              {feature.icon === 'file' && (
                <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              )}
              {feature.icon === 'chat' && (
                <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
              )}
              {feature.icon === 'shield' && (
                <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              )}
              {feature.icon === 'refresh' && (
                <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
              )}
            </div>
            <div>
              <h3 class="font-bold text-surface-900 mb-1">{feature.title}</h3>
              <p class="text-sm text-surface-500">{feature.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ 섹션 -->
  <section class="py-16 bg-surface-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-surface-900 mb-10 text-center">
        자주 묻는 질문
      </h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-white rounded-xl border border-surface-200 overflow-hidden">
            <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
              <span class="font-semibold text-surface-900">{faq.question}</span>
              <svg class="w-5 h-5 text-surface-400 transition-transform group-open:rotate-180 shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-surface-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- 하단 CTA 섹션 -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-surface-900 mb-4">
        궁금한 점이 있으신가요?
      </h2>
      <p class="text-surface-600 mb-8 max-w-xl mx-auto">
        프리미엄 템플릿, 커스터마이징, 가격 등 어떤 질문이든 편하게 문의해 주세요.
      </p>
      <a
        href={GOOGLE_FORM_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center px-6 py-3 bg-primary-500 text-white font-semibold rounded-lg hover:bg-primary-600 transition-colors text-lg"
      >
        문의하기
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
