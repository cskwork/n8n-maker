---
/**
 * EmptyCategory 컴포넌트
 * - 템플릿이 없는 카테고리에서 안내 메시지 표시
 * - 다른 카테고리 링크 목록 제공 (currentSlug 제외)
 */

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

const allCategories: Record<string, string> = {
  finance: '금융',
  marketing: '마케팅',
  hr: 'HR',
  it: 'IT/DevOps',
};

// 현재 카테고리를 제외한 나머지 링크
const otherCategories = Object.entries(allCategories)
  .filter(([slug]) => slug !== currentSlug)
  .map(([slug, name]) => ({ slug, name }));
---

<section class="pb-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center py-16 bg-surface-50 rounded-xl border border-surface-200">
      <div class="text-4xl mb-4" aria-hidden="true">
        <svg class="w-12 h-12 mx-auto text-surface-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
        </svg>
      </div>
      <h2 class="text-xl font-bold text-surface-700 mb-2">준비 중입니다</h2>
      <p class="text-surface-500 mb-8 max-w-md mx-auto">
        이 카테고리의 워크플로우 템플릿을 열심히 제작하고 있습니다.<br />
        조금만 기다려 주세요!
      </p>
      <div>
        <p class="text-sm font-medium text-surface-600 mb-3">다른 카테고리 둘러보기</p>
        <div class="flex flex-wrap justify-center gap-3">
          {otherCategories.map((cat) => (
            <a
              href={`/n8n-maker/category/${cat.slug}`}
              class="inline-flex items-center px-4 py-2 bg-white border border-surface-200 rounded-lg text-sm font-medium text-surface-700
                     hover:border-primary-300 hover:text-primary-600 transition-all"
            >
              {cat.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
