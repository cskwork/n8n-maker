---
/**
 * Breadcrumb 컴포넌트
 * - Props: items 배열 (label + href)
 * - "홈" 항목은 항상 첫 번째
 * - " > " 구분자로 연결
 * - 마지막 항목은 링크 없이 현재 위치 표시
 */

interface Props {
  items: Array<{ label: string; href: string }>;
}

const { items } = Astro.props;

// 홈을 첫 번째에 추가
const breadcrumbs = [
  { label: '홈', href: '/n8n-marketplace/' },
  ...items,
];
---

<nav aria-label="Breadcrumb" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
  <ol class="flex items-center gap-1 text-sm text-surface-500">
    {breadcrumbs.map((item, index) => (
      <li class="flex items-center gap-1">
        {index > 0 && <span class="text-surface-300">&gt;</span>}
        {index < breadcrumbs.length - 1 ? (
          <a
            href={item.href}
            class="hover:text-primary-600 transition-colors"
          >
            {item.label}
          </a>
        ) : (
          <span class="font-semibold text-surface-700">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
