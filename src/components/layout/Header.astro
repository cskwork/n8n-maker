---
/**
 * Header 컴포넌트
 * - 왼쪽: 로고 "n8n Market" (홈 링크)
 * - 중앙: 카테고리 4개 링크 (금융/마케팅/HR/IT)
 * - 오른쪽: CTA "시작하기" 버튼
 * - 모바일: 햄버거 메뉴 버튼 (md 미만에서 표시)
 */
---

<header class="sticky top-0 z-50 bg-white border-b border-surface-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- 로고 -->
      <a href="/n8n-maker/" class="text-xl font-bold text-primary-600 hover:text-primary-700 transition-colors">
        n8n Market
      </a>

      <!-- 데스크톱 네비게이션 (md 이상) -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="/n8n-maker/category/finance" class="text-surface-700 hover:text-primary-600 font-medium transition-colors">
          금융
        </a>
        <a href="/n8n-maker/category/marketing" class="text-surface-700 hover:text-primary-600 font-medium transition-colors">
          마케팅
        </a>
        <a href="/n8n-maker/category/hr" class="text-surface-700 hover:text-primary-600 font-medium transition-colors">
          HR
        </a>
        <a href="/n8n-maker/category/it" class="text-surface-700 hover:text-primary-600 font-medium transition-colors">
          IT/DevOps
        </a>
      </nav>

      <!-- 데스크톱 CTA (md 이상) -->
      <a
        href="/n8n-maker/#get-started"
        class="hidden md:inline-flex items-center px-5 py-2 bg-primary-500 text-white font-medium rounded-lg hover:bg-primary-600 transition-colors"
      >
        시작하기
      </a>

      <!-- 모바일 햄버거 버튼 (md 미만) -->
      <button
        id="menu-toggle"
        type="button"
        class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg text-surface-700 hover:bg-surface-100 transition-colors"
        aria-label="메뉴 열기"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <!-- 햄버거 아이콘 -->
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</header>
