---
/**
 * BaseLayout 컴포넌트
 * - 모든 페이지의 공통 레이아웃
 * - HTML head (charset, viewport, meta, title, OG, Twitter Card, JSON-LD)
 * - Header + (Breadcrumb) + main slot + Footer
 */
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import MobileMenu from '../components/layout/MobileMenu.astro';
import Footer from '../components/layout/Footer.astro';
import Breadcrumb from '../components/layout/Breadcrumb.astro';

interface Props {
  title: string;
  description?: string;
  breadcrumbs?: Array<{ label: string; href: string }>;
  ogImage?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = 'n8n 워크플로우 템플릿 마켓플레이스 - 비개발자를 위한 업무 자동화',
  breadcrumbs,
  ogImage = '/n8n-maker/og-image.png',
  ogType = 'website',
  jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
const fullTitle = `${title} | n8n 마켓플레이스`;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>

    {/* Canonical URL */}
    <link rel="canonical" href={canonicalURL.href} />

    {/* Open Graph 메타 태그 */}
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content="n8n 마켓플레이스" />

    {/* Twitter Card 메타 태그 */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />

    {/* 네이버 사이트 인증 - TODO: 실제 인증 코드로 교체 필요 */}
    <meta name="naver-site-verification" content="NAVER_VERIFICATION_CODE_HERE" />

    {/* JSON-LD 구조화 데이터 */}
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="min-h-screen flex flex-col" style="background-color: var(--color-bg); color: var(--color-text);">
    <Header />
    <MobileMenu />
    {breadcrumbs && <Breadcrumb items={breadcrumbs} />}
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
