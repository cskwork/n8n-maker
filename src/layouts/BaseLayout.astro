---
/**
 * BaseLayout 컴포넌트
 * - 모든 페이지의 공통 레이아웃
 * - HTML head (charset, viewport, meta, title)
 * - Header + (Breadcrumb) + main slot + Footer
 */
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import MobileMenu from '../components/layout/MobileMenu.astro';
import Footer from '../components/layout/Footer.astro';
import Breadcrumb from '../components/layout/Breadcrumb.astro';

interface Props {
  title: string;
  description?: string;
  breadcrumbs?: Array<{ label: string; href: string }>;
}

const {
  title,
  description = 'n8n 워크플로우 템플릿 마켓플레이스 - 비개발자를 위한 업무 자동화',
  breadcrumbs,
} = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | n8n 마켓플레이스</title>
  </head>
  <body class="min-h-screen flex flex-col" style="background-color: var(--color-bg); color: var(--color-text);">
    <Header />
    <MobileMenu />
    {breadcrumbs && <Breadcrumb items={breadcrumbs} />}
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
